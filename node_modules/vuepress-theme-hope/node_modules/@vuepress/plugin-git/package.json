{
  "name": "@vuepress/plugin-git",
  "version": "2.0.0-rc.124",
  "description": "VuePress plugin - git",
  "keywords": [
    "git",
    "plugin",
    "vuepress",
    "vuepress-plugin"
  ],
  "homepage": "https://ecosystem.vuejs.press/plugins/development/get.html",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": "meteorlxy",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "plugins/development/plugin-git"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": [
    "./lib/client/styles/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./lib/node/index.d.ts",
      "default": "./lib/node/index.js"
    },
    "./client": {
      "types": "./lib/client/index.d.ts",
      "default": "./lib/client/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vuepress/helper": "2.0.0-rc.124",
    "@vueuse/core": "^14.2.1",
    "rehype-parse": "^9.0.1",
    "rehype-sanitize": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "unified": "^11.0.5",
    "vue": "^3.5.29"
  },
  "peerDependencies": {
    "vuepress": "2.0.0-rc.26"
  },
  "gitHead": "f17e7479b1ef3c06814b6107df9188ba351702da"
