{
  "name": "@vuepress/plugin-comment",
  "version": "2.0.0-rc.124",
  "description": "VuePress plugin - comment",
  "keywords": [
    "artalk",
    "comment",
    "giscus",
    "plugin",
    "twikoo",
    "vuepress",
    "vuepress-plugin",
    "waline"
  ],
  "homepage": "https://ecosystem.vuejs.press/plugins/blog/comment/",
  "bugs": {
    "url": "https://github.com/vuepress/ecosystem/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Mr.Hope",
    "email": "mister-hope@outlook.com",
    "url": "https://mister-hope.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vuepress/ecosystem.git",
    "directory": "plugins/blog/plugin-comment"
  },
  "files": [
    "lib"
  ],
  "type": "module",
  "sideEffects": [
    "./lib/client/styles/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./lib/node/index.d.ts",
      "default": "./lib/node/index.js"
    },
    "./client": {
      "types": "./lib/client/index.d.ts",
      "default": "./lib/client/index.js"
    },
    "./client/*": "./lib/client/*",
    "./pageview": {
      "types": "./lib/client/pageview/noop.d.ts",
      "default": "./lib/client/pageview/noop.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@vuepress/helper": "2.0.0-rc.124",
    "@vueuse/core": "^14.2.1",
    "giscus": "^1.6.0",
    "vue": "^3.5.29"
  },
  "peerDependencies": {
    "@waline/client": "^3.7.1",
    "artalk": "^2.9.1",
    "twikoo": "^1.6.41",
    "vuepress": "2.0.0-rc.26"
  },
  "peerDependenciesMeta": {
    "@waline/client": {
      "optional": true
    },
    "artalk": {
      "optional": true
    },
    "twikoo": {
      "optional": true
    }
  },
  "gitHead": "f17e7479b1ef3c06814b6107df9188ba351702da"
